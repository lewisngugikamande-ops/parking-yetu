<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Parking Yetu - Smart Parking</title>
    <link rel="stylesheet" href="css/main.css">
    <link rel="stylesheet" href="css/dashboard.css">
    <link rel="stylesheet" href="css/atmosphere.css">
    <style>
        body { 
            margin: 0; 
            font-family: system-ui, -apple-system, sans-serif; 
            background: #0a0a0f; 
            color: #e8e8f0; 
            min-height: 100vh; 
        }
        .auth-screen { display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 20px; }
        .auth-box { background: rgba(255,255,255,0.05); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.1); border-radius: 24px; padding: 40px 32px; max-width: 420px; width: 100%; }
        .auth-box h2 { font-size: 28px; font-weight: 700; margin-bottom: 4px; text-align: center; }
        .auth-box .sub { font-size: 14px; color: rgba(255,255,255,0.5); text-align: center; margin-bottom: 28px; }
        .auth-box input, .auth-box select { width: 100%; padding: 12px 16px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.05); color: #e8e8f0; font-size: 16px; margin-bottom: 12px; }
        .auth-box input:focus { outline: none; border-color: #6C3CE1; }
        .auth-error { display: none; padding: 12px; border-radius: 12px; margin-bottom: 12px; background: rgba(255,45,85,0.1); color: #ef4444; font-size: 14px; }
        .auth-error.show { display: block; }
        .auth-switch { text-align: center; margin-top: 16px; font-size: 14px; color: rgba(255,255,255,0.5); }
        .auth-switch span { color: #6C3CE1; cursor: pointer; font-weight: 600; }
        .btn-primary { background: #6C3CE1; color: white; border: none; padding: 12px 24px; border-radius: 12px; font-weight: 600; cursor: pointer; font-size: 16px; width: 100%; transition: all 0.3s; }
        .btn-primary:hover { background: #7C4CFF; transform: translateY(-2px); }
        .btn-primary:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
        .theme-toggle { position: fixed; top: 20px; right: 20px; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 50%; width: 44px; height: 44px; font-size: 20px; cursor: pointer; z-index: 1000; }
        #appContainer { display: none; z-index: 1; position: relative; }
        #app { min-height: 100vh; padding: 20px; }
    </style>
</head>
<body>
    <!-- Theme Toggle -->
    <button class="theme-toggle" id="themeToggle" onclick="window.toggleTheme()">🌙</button>

    <!-- Auth Screen -->
    <div class="auth-screen" id="authScreen">
        <div class="auth-box">
            <h2>🚗 Parking Yetu</h2>
            <p class="sub" id="authSubtitle">Smart Parking Platform</p>
            <div id="loginForm">
                <input type="text" id="loginEmail" placeholder="Username or Email">
                <input type="password" id="loginPassword" placeholder="Password">
                <div class="auth-error" id="loginError">Invalid credentials</div>
                <button onclick="window.handleLogin()" class="btn-primary">🚀 Login</button>
                <div class="auth-switch">
                    Don't have an account? <span onclick="window.switchAuthMode('register')">Register</span>
                </div>
            </div>
            <div id="registerForm" style="display:none;">
                <input type="text" id="registerName" placeholder="Full Name">
                <input type="email" id="registerEmail" placeholder="Email Address">
                <input type="password" id="registerPassword" placeholder="Password (min 6 chars)">
                <select id="registerRole">
                    <option value="admin">👨💼 Admin</option>
                    <option value="security_manager">👔 Security Manager</option>
                    <option value="guard">🛡️ Security Guard</option>
                    <option value="receptionist">📋 Receptionist</option>
                    <option value="driver">🚗 Driver</option>
                </select>
                <div class="auth-error" id="registerError">Registration failed</div>
                <button onclick="window.handleRegister()" class="btn-primary">✨ Register</button>
                <div class="auth-switch">
                    Already have an account? <span onclick="window.switchAuthMode('login')">Login</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Main App Container -->
    <div id="appContainer" style="display:none;">
        <div id="app"></div>
    </div>

    <!-- ==========================================
       ATMOSPHERE - Background Effects
       ========================================== -->
    <div id="atmosphere-container">
        <div id="atmosphereSky" style="position:fixed;top:0;left:0;right:0;bottom:0;z-index:0;background:linear-gradient(180deg,#050510 0%,#0a0a1a 30%,#1a0a2e 60%,#2a1a4e 100%);pointer-events:none;"></div>
        <canvas id="starsCanvas" style="position:fixed;top:0;left:0;right:0;bottom:0;z-index:0;pointer-events:none;"></canvas>
        <canvas id="cityCanvas" style="position:fixed;bottom:0;left:0;right:0;height:200px;z-index:0;pointer-events:none;opacity:0.2;"></canvas>
        <canvas id="trafficCanvas" style="position:fixed;top:0;left:0;right:0;bottom:0;z-index:0;pointer-events:none;"></canvas>
    </div>

    <!-- Main App Entry -->
    <script type="module" src="/src/index.js"></script>

    <script>
    // ==========================================
    // ATMOSPHERE - Draw Background Effects
    // ==========================================
    (function() {
        console.log('🌅 Drawing atmosphere...');
        
        // STARS
        const starsCanvas = document.getElementById('starsCanvas');
        if (starsCanvas) {
            starsCanvas.width = window.innerWidth;
            starsCanvas.height = window.innerHeight;
            const ctx = starsCanvas.getContext('2d');
            for (let i = 0; i < 200; i++) {
                const x = Math.random() * starsCanvas.width;
                const y = Math.random() * starsCanvas.height * 0.7;
                const r = 0.5 + Math.random() * 1.5;
                const opacity = 0.3 + Math.random() * 0.7;
                ctx.beginPath();
                ctx.arc(x, y, r, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(255,255,255,${opacity * 0.6})`;
                ctx.fill();
            }
            console.log('✅ Stars drawn');
        }
        
        // CITYSCAPE - Full Width
        const cityCanvas = document.getElementById('cityCanvas');
        if (cityCanvas) {
            cityCanvas.width = window.innerWidth;
            cityCanvas.height = 200;
            const ctx = cityCanvas.getContext('2d');
            ctx.clearRect(0, 0, cityCanvas.width, cityCanvas.height);
            
            const buildings = [];
            const count = 40;
            const spacing = cityCanvas.width / count;
            
            for (let i = 0; i < count; i++) {
                const width = 15 + Math.random() * 40;
                const height = 30 + Math.random() * 130;
                const x = i * spacing + (spacing - width) / 2;
                buildings.push({ x, w: width, h: height });
            }
            
            buildings.forEach(b => {
                ctx.fillStyle = `rgba(255,255,255,${0.04 + Math.random() * 0.06})`;
                ctx.fillRect(b.x, cityCanvas.height - b.h, b.w, b.h);
                for (let r = 0; r < Math.floor(b.h / 15); r++) {
                    for (let c = 0; c < Math.floor(b.w / 12); c++) {
                        if (Math.random() > 0.5) {
                            ctx.fillStyle = `rgba(255,200,100,${0.05 + Math.random() * 0.15})`;
                            ctx.fillRect(b.x + c * 12 + 2, cityCanvas.height - b.h + r * 15 + 5, 5, 7);
                        }
                    }
                }
            });
            console.log('✅ Cityscape drawn full width');
        }
        
        // TRAFFIC
        const trafficCanvas = document.getElementById('trafficCanvas');
        if (trafficCanvas) {
            trafficCanvas.width = window.innerWidth;
            trafficCanvas.height = window.innerHeight;
            const ctx = trafficCanvas.getContext('2d');
            let cars = [];
            const colors = ['#6C3CE1', '#00D4FF', '#00FF88', '#FF6B35', '#FF2D55', '#FFD700'];
            for (let i = 0; i < 20; i++) {
                cars.push({
                    x: Math.random() * trafficCanvas.width,
                    y: trafficCanvas.height - 70 - Math.random() * 120,
                    size: 20 + Math.random() * 30,
                    speed: 0.5 + Math.random() * 1.5,
                    color: colors[Math.floor(Math.random() * colors.length)]
                });
            }
            function animateCars() {
                ctx.clearRect(0, 0, trafficCanvas.width, trafficCanvas.height);
                cars.forEach(car => {
                    car.x += car.speed;
                    if (car.x > trafficCanvas.width + 50) {
                        car.x = -50;
                        car.y = trafficCanvas.height - 70 - Math.random() * 120;
                    }
                    ctx.shadowColor = 'rgba(255,200,50,0.15)';
                    ctx.shadowBlur = 20;
                    ctx.fillStyle = car.color;
                    ctx.fillRect(car.x, car.y - car.size/2, car.size * 1.8, car.size * 0.6);
                    ctx.fillStyle = car.color;
                    ctx.globalAlpha = 0.7;
                    ctx.fillRect(car.x + car.size * 0.3, car.y - car.size/2 - 4, car.size * 0.7, car.size * 0.3);
                    ctx.globalAlpha = 1;
                    ctx.shadowBlur = 0;
                    const grad = ctx.createRadialGradient(car.x + car.size * 1.8, car.y, 2, car.x + car.size * 2.2, car.y, 40);
                    grad.addColorStop(0, 'rgba(255,200,50,0.3)');
                    grad.addColorStop(1, 'rgba(255,200,50,0)');
                    ctx.fillStyle = grad;
                    ctx.beginPath();
                    ctx.arc(car.x + car.size * 2.2, car.y, 40, 0, Math.PI * 2);
                    ctx.fill();
                });
                requestAnimationFrame(animateCars);
            }
            animateCars();
            console.log('✅ Traffic animated');
        }
        
        // Make dashboard transparent
        const app = document.getElementById('app');
        if (app) {
            app.style.background = 'transparent';
            app.style.position = 'relative';
            app.style.zIndex = '1';
        }
        
        console.log('🎨 Atmosphere ready!');
    })();
    </script>
</body>
</html>
