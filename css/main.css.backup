cd ~/projects/parking-yetu

# This is the complete CSS from your original app
cat > css/main.css << 'EOF'
/* ==========================================
   Parking Yetu - Complete CSS
   ========================================== */

:root {
    --primary: #6C3CE1;
    --primary-glow: rgba(108, 60, 225, 0.4);
    --secondary: #00D4FF;
    --accent: #00FF88;
    --warning: #FF6B35;
    --danger: #FF2D55;
    --bg-primary: #0A0A0F;
    --bg-secondary: #12121A;
    --bg-card: rgba(255, 255, 255, 0.04);
    --bg-card-hover: rgba(255, 255, 255, 0.08);
    --text-primary: #FFFFFF;
    --text-secondary: #B8B8D0;
    --text-muted: #6A6A8A;
    --glass-bg: rgba(255, 255, 255, 0.04);
    --glass-border: rgba(255, 255, 255, 0.08);
    --glass-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    --gradient-primary: linear-gradient(135deg, #6C3CE1, #00D4FF);
    --transition-speed: 0.3s;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
}

body {
    font-family: 'Inter', Arial, sans-serif;
    background: var(--bg-primary);
    min-height: 100vh;
    padding: 15px 15px 80px;
    color: var(--text-primary);
    overflow-x: hidden;
}

.container {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
}

/* ==========================================
   AUTH SCREEN
   ========================================== */
.auth-screen {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 20px;
    position: relative;
    z-index: 1;
}

.auth-screen.hidden {
    display: none;
}

.auth-box {
    background: var(--glass-bg);
    backdrop-filter: blur(20px);
    border-radius: 32px;
    padding: 40px 32px;
    max-width: 420px;
    width: 100%;
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow);
    transition: all 0.3s ease;
}

.auth-box h2 {
    font-family: 'Orbitron', monospace;
    font-size: 28px;
    text-align: center;
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.auth-box .sub {
    text-align: center;
    color: var(--text-muted);
    font-size: 14px;
    margin-bottom: 24px;
    letter-spacing: 2px;
}

.auth-box input,
.auth-box select {
    width: 100%;
    padding: 14px 18px;
    margin: 8px 0;
    font-size: 16px;
    border-radius: 16px;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    color: var(--text-primary);
    font-family: 'Inter', sans-serif;
    min-height: 52px;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
}

.auth-box input:focus,
.auth-box select:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 20px rgba(108, 60, 225, 0.15);
}

.auth-box .auth-error {
    color: var(--danger);
    font-size: 14px;
    text-align: center;
    display: none;
    margin-top: 10px;
    padding: 10px;
    background: rgba(255, 45, 85, 0.08);
    border-radius: 12px;
}

.auth-box .auth-error.show {
    display: block;
}

.auth-box .auth-switch {
    text-align: center;
    color: var(--text-muted);
    font-size: 14px;
    margin-top: 16px;
}

.auth-box .auth-switch span {
    color: var(--secondary);
    cursor: pointer;
    font-weight: 600;
    transition: color 0.3s ease;
}

/* ==========================================
   BACKGROUND TRANSPORT
   ========================================== */
.transport-bg {
    position: fixed;
    bottom: 0;
    font-size: 20px;
    z-index: 0;
    opacity: 0.03;
    pointer-events: none;
    white-space: nowrap;
    user-select: none;
    will-change: transform;
}

.transport-right {
    animation: moveRight linear infinite;
}

.transport-left {
    animation: moveLeft linear infinite;
}

@keyframes moveRight {
    0% { transform: translateX(-200px) scaleX(1) translateZ(0); }
    100% { transform: translateX(calc(100vw + 200px)) scaleX(1) translateZ(0); }
}

@keyframes moveLeft {
    0% { transform: translateX(calc(100vw + 200px)) scaleX(-1) translateZ(0); }
    100% { transform: translateX(-200px) scaleX(-1) translateZ(0); }
}

.transport-slow { animation-duration: 40s; }
.transport-medium { animation-duration: 30s; }
.transport-fast { animation-duration: 20s; }

.transport-y-1 { bottom: 5%; }
.transport-y-2 { bottom: 15%; }
.transport-y-3 { bottom: 25%; }
.transport-y-4 { bottom: 35%; }
.transport-y-5 { bottom: 45%; }
.transport-y-6 { bottom: 55%; }
.transport-y-7 { bottom: 65%; }
.transport-y-8 { bottom: 75%; }

.transport-small { font-size: 14px; }
.transport-medium-size { font-size: 20px; }
.transport-large { font-size: 30px; }

/* ==========================================
   CARDS
   ========================================== */
.card {
    background: var(--glass-bg);
    backdrop-filter: blur(20px);
    border-radius: 24px;
    padding: 24px;
    margin-bottom: 16px;
    border: 1px solid var(--glass-border);
    box-shadow: var(--glass-shadow);
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    position: relative;
    overflow: hidden;
    will-change: transform;
}

.card:hover {
    transform: translateY(-4px) translateZ(0);
    border-color: rgba(108, 60, 225, 0.2);
    box-shadow: 0 12px 40px rgba(108, 60, 225, 0.15);
}

.card h3 {
    font-family: 'Orbitron', monospace;
    font-size: 16px;
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.card h3 .accent {
    color: var(--secondary);
}

/* ==========================================
   BUTTONS
   ========================================== */
button {
    width: 100%;
    padding: 16px;
    margin: 6px 0;
    font-size: 18px;
    font-weight: 600;
    border-radius: 16px;
    border: none;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    font-family: 'Inter', sans-serif;
    text-transform: uppercase;
    min-height: 56px;
    position: relative;
    overflow: hidden;
    will-change: transform;
}

button:hover {
    transform: translateY(-2px) translateZ(0);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
}

.btn-primary {
    background: var(--gradient-primary);
    color: white;
    box-shadow: 0 4px 20px rgba(108, 60, 225, 0.3);
}

.btn-secondary {
    background: linear-gradient(135deg, #00D4FF, #00FF88);
    color: var(--bg-primary);
    box-shadow: 0 4px 20px rgba(0, 212, 255, 0.2);
}

.btn-danger {
    background: linear-gradient(135deg, #FF2D55, #FF6B6B);
    color: white;
}

.btn-success {
    background: linear-gradient(135deg, #00FF88, #00D4AA);
    color: var(--bg-primary);
}

.btn-ghost {
    background: var(--glass-bg);
    color: var(--text-secondary);
    border: 1px solid var(--glass-border);
}

/* ==========================================
   LAYOUT
   ========================================== */
.grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
}

.stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 10px;
    margin: 15px 0;
}

.stat-box {
    background: var(--glass-bg);
    padding: 15px 10px;
    border-radius: 16px;
    text-align: center;
    border: 1px solid var(--glass-border);
    transition: all 0.3s ease;
}

.stat-box .stat-number {
    font-family: 'Orbitron', monospace;
    font-size: 28px;
    font-weight: 700;
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.stat-box .stat-label {
    font-size: 11px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
}

/* ==========================================
   VEHICLE GRID
   ========================================== */
.vehicle-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 8px;
    margin: 10px 0;
}

.vehicle-grid button {
    padding: 14px 6px;
    font-size: 13px;
    background: var(--glass-bg);
    color: var(--text-secondary);
    border: 1px solid var(--glass-border);
    border-radius: 14px;
    cursor: pointer;
    transition: all 0.3s ease;
    min-height: 72px;
    text-transform: uppercase;
    font-family: 'Inter', sans-serif;
}

.vehicle-grid button.vehicle-active {
    border-color: var(--primary);
    background: var(--gradient-primary);
    color: white;
}

.vehicle-grid button .vehicle-icon {
    display: block;
    font-size: 28px;
    margin-bottom: 4px;
}

/* ==========================================
   THEME TOGGLE
   ========================================== */
.theme-toggle {
    position: fixed;
    top: 20px;
    right: 80px;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    color: var(--text-secondary);
    font-size: 20px;
    cursor: pointer;
    z-index: 100;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: auto;
    padding: 0;
}

.theme-toggle:hover {
    transform: rotate(30deg) scale(1.1);
    border-color: var(--primary);
}

/* ==========================================
   LIGHT THEME
   ========================================== */
body.light-theme {
    --bg-primary: #F5F5FA;
    --bg-secondary: #FFFFFF;
    --text-primary: #1A1A2E;
    --text-secondary: #4A4A6A;
    --text-muted: #8A8AAA;
    --glass-bg: rgba(255, 255, 255, 0.8);
    --glass-border: rgba(0, 0, 0, 0.08);
}

body.light-theme .card {
    background: rgba(255, 255, 255, 0.9);
    border-color: rgba(0, 0, 0, 0.08);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.06);
}

body.light-theme .header {
    background: rgba(255, 255, 255, 0.9);
    border-color: rgba(0, 0, 0, 0.08);
}

/* ==========================================
   RESPONSIVE
   ========================================== */
@media (max-width: 480px) {
    .stats-grid {
        grid-template-columns: 1fr 1fr 1fr;
    }
    .stat-box .stat-number {
        font-size: 22px;
    }
    .grid-2 {
        grid-template-columns: 1fr;
    }
    .vehicle-grid {
        grid-template-columns: 1fr 1fr 1fr 1fr;
    }
    .vehicle-grid button {
        font-size: 11px;
        padding: 12px 4px;
        min-height: 64px;
    }
    .theme-toggle {
        top: 20px;
        right: 70px;
        width: 38px;
        height: 38px;
        font-size: 16px;
    }
    .transport-bg {
        display: none !important;
    }
}

@media (max-width: 380px) {
    .vehicle-grid {
        grid-template-columns: 1fr 1fr 1fr;
    }
}

@media (prefers-reduced-motion: reduce) {
    .transport-bg {
        display: none !important;
    }
    .card:hover {
        transform: none !important;
    }
    button:hover {
        transform: none !important;
    }
}
EOF

echo "✅ CSS restored!"
wc -l css/main.css
ls -lh css/main.css

